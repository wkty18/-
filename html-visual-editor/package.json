{
  "name": "html-visual-editor",
  "version": "1.0.0",
  "description": "可视化HTML编辑器 — 所见即所得编辑网页",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.htmlvisualeditor.app",
    "productName": "HTML可视化编辑器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "templates/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052"
    }
  },
  "devDependencies": {
    "electron": "^33.4.0",
    "electron-builder": "^25.1.0"
  },
  "keywords": [
    "html",
    "editor",
    "wysiwyg",
    "visual"
  ],
  "author": "RadiantSoul",
  "license": "MIT"
}
